datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  // previewFeatures = []
}

generator dbml {
  provider = "prisma-dbml-generator"
}

// ==========================================
// 1. 全局枚举 (Enums)
// ==========================================

enum UserStatus {
  PENDING // 待激活
  ACTIVE // 正常/已激活
  INACTIVE // 已禁用
}

enum Sex {
  MALE
  FEMALE
  UNKNOWN
}

enum MenuType {
  DIRECTORY // 目录
  MENU // 菜单
  BUTTON // 按钮/权限点
}

enum Method {
  GET
  POST
  PUT
  PATCH
  DELETE
}

// 考勤打卡状态
enum AttendanceStatus {
  WORK // 上班
  REST // 休息
  LEAVE // 请假
}

// 任务或报告状态
enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

// ==========================================
// 2. 核心底座：RBAC 权限与用户 (System & RBAC)
// ==========================================

model User {
  id String @id @default(cuid())

  // --- 身份与登录凭证 (Credentials) ---
  phone    String? @unique // 手机号（可选，但一旦有必须唯一）
  userName String  @unique // 登录账号（必填且唯一，如 admin123）
  password String // 哈希加密后的密码

  // --- 用户资料 (Profile) ---
  name   String? // 真实姓名（如 "张三", "John"）。强烈建议在业务层面（如学生认证时）设为必填。
  // realName String?  // (备选) 如果 name 太宽泛，用 realName 语义最精确
  idCard String? @unique // 身份证（可选）
  openId String? @unique // 预留给微信小程序的 openId

  avatar String? // 头像
  sex    Sex     @default(UNKNOWN) // 性别

  status UserStatus @default(ACTIVE)

  // 数据隔离：用户所属的机构 (可为空表示自由用户/平台管理员)
  schoolId     String?
  school       School?     @relation(fields: [schoolId], references: [id])
  enterpriseId String?
  enterprise   Enterprise? @relation(fields: [enterpriseId], references: [id])

  // 关系映射
  roles             Role[]             @relation("UserRoles")
  logs              Log[]
  sentMessages      Message[]          @relation("SentMessages")
  receivedMessages  Message[]          @relation("ReceivedMessages")
  classMemberships  ClassMember[]
  attendances       Attendance[]
  reports           Report[]
  feedbacks         Feedback[]
  assignedTasks     Task[]             @relation("AssignedTasks") // 被分配的任务
  createdTasks      Task[]             @relation("CreatedTasks") // 发布的任务
  announcementReads AnnouncementRead[]

  // 新增关系字段
  receivedEvaluations Evaluation[] @relation("StudentEvaluations") // 作为学生收到的评价
  givenEvaluations    Evaluation[] @relation("MentorEvaluations") // 作为导师给出的评价

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique // 角色名称 (如：超级管理员、学校管理员)
  code        String  @unique // 角色编码 (如：SUPER_ADMIN, SCHOOL_ADMIN)
  description String?
  sort        Int     @default(0)

  users User[] @relation("UserRoles")
  menus Menu[] @relation("RoleMenus")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Menu {
  id       String  @id @default(cuid())
  parentId String?
  parent   Menu?   @relation("MenuHierarchy", fields: [parentId], references: [id])
  children Menu[]  @relation("MenuHierarchy")

  title      String // 菜单名称
  type       MenuType @default(MENU)
  path       String? // 路由地址
  component  String? // 组件路径
  permission String? // 权限标识 (如 sys:user:add)
  icon       String?
  sort       Int      @default(0)
  isHidden   Boolean  @default(false)

  roles Role[] @relation("RoleMenus")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 3. 机构域：企业与学校信息 (Organizations)
// ==========================================

model Enterprise {
  id          String  @id @default(cuid())
  name        String  @unique // 企业名称
  logo        String?
  description String? @db.Text

  // 联系人信息
  contactName   String?
  contactPhone  String?
  contactWechat String?
  contactQrCode String? // 微信二维码图片地址

  status Boolean @default(true) // 启用/禁用状态

  users    User[]
  jobPosts JobPost[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  evaluations Evaluation[] // 企业名下的所有评价记录
}

model School {
  id          String  @id @default(cuid())
  name        String  @unique
  logo        String? // 学校LOGO
  description String? // 简介
  address     String? // 地址
  contactName String? // 负责人姓名
  phone       String? // 负责人电话
  status      String  @default("ACTIVE") // ACTIVE, INACTIVE

  users         User[]
  classes       Class[]
  announcements Announcement[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  evaluations Evaluation[] // 本校学生在各企业收到的评价汇总
}

// 班级管理
model Class {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name        String // 例如 "机电3班"
  year        Int? // 届别，如 2026
  status      String  @default("ACTIVE")
  description String?
  grade       String? // 👈 确保这行存在 (年级)

  classMemberships ClassMember[] // 👈 确保这里是 classMemberships

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, schoolId]) // 同一学校内班级名不能重复
}

// ==========================================
// 4. 业务域：招聘与教学管理 (Business Core)
// ==========================================

// 企业岗位 (求职类)
model JobPost {
  id           String     @id @default(cuid())
  enterpriseId String
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  title       String
  content     String  @db.Text
  city        String?
  salaryRange String? // 薪资范围，如 "100-150/天"
  isActive    Boolean @default(true) // 是否正在招聘

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 班级成员 (包含学生和教师)
model ClassMember {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  classId String
  // class     Class  @relation(fields: [classId], references: [id])

  role   String @default("STUDENT") // STUDENT 或 TEACHER 
  status String @default("ACTIVE") // 状态：PENDING(待审批), ACTIVE(已加入), REJECTED(已拒绝)

  createdAt DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id])

  @@unique([classId, userId]) // 一个人在一个班里只能有一条记录
}

// 学校公告
model Announcement {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  title    String
  content  String @db.Text

  reads AnnouncementRead[]

  createdAt DateTime @default(now())
}

// 公告已读记录 (关联学生)
model AnnouncementRead {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  readAt DateTime @default(now())

  @@unique([userId, announcementId])
}

// ==========================================
// 5. 实习过程管理 (Internship Management)
// ==========================================

// 签到打卡记录 (对应前端的首页日历打卡)
model Attendance {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      String // 打卡日期, e.g., "2026-04-15"
  status    AttendanceStatus // WORK | REST | LEAVE
  workHours Decimal?         @db.Decimal(4, 1) // 记录工时，例如 8.0
  quote     String? // 碎碎念/心情记录

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date]) // 一天只能有一条最终记录
}

// 实习任务
model Task {
  id       String     @id @default(cuid())
  title    String
  content  String     @db.Text
  status   TaskStatus @default(PENDING)
  deadline DateTime?

  publisherId String // 任务发布者 (教师/企业管理)
  publisher   User   @relation("CreatedTasks", fields: [publisherId], references: [id])
  assigneeId  String // 任务接收者 (实习生)
  assignee    User   @relation("AssignedTasks", fields: [assigneeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 周报/实习报告
model Report {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String // WEEKLY(周报), MONTHLY(月报), FINAL(实习总结)
  content     String @db.Text
  attachments Json? // 附件列表，存 JSON 数组

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 问题反馈
model Feedback {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  content    String  @db.Text
  reply      String? @db.Text // 管理员回复
  isResolved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 6. 系统通用管理 (System Common)
// ==========================================

// 站内信/消息管理
model Message {
  id      String  @id @default(cuid())
  title   String
  content String  @db.Text
  isRead  Boolean @default(false)

  senderId   String? // 发送者 (为空代表系统消息)
  sender     User?   @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User    @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// 操作日志
model Log {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ip      String
  action  String // 操作描述
  method  Method
  params  Json? // 请求参数
  os      String?
  browser String?

  createdAt DateTime @default(now())
}

// 系统设置 (KV配置)
model SystemSetting {
  key         String  @id // 例如 "system_logo", "allow_register"
  value       String  @db.Text
  description String?

  updatedAt DateTime @updatedAt
}

// 评价表
model Evaluation {
  id String @id @default(cuid())

  // 1. 关联实习生 (User)
  studentId String
  student   User   @relation("StudentEvaluations", fields: [studentId], references: [id], onDelete: Cascade)

  // 2. 关联评价人/企业导师 (User)
  mentorId String
  mentor   User   @relation("MentorEvaluations", fields: [mentorId], references: [id])

  // 3. 关联企业 (Enterprise)
  enterpriseId String
  enterprise   Enterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  // 4. 关联学校 (School) - 冗余存储方便学校端直接统计
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  score   Int // 评分，如 1-5 分
  content String? @db.Text // 评语

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
