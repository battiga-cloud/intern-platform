datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  // previewFeatures = []
}

generator dbml {
  provider = "prisma-dbml-generator"
}

// 定义用户角色：超级管理员、管理员(平台)、学校管理员、企业管理员和普通用户）
enum Role {
  SUPER_ADMIN
  ADMIN
  SCHOOL_ADMIN
  COMPANY_ADMIN
  USER
}

// 定义用户状态：待激活、已激活、已禁用
enum UserStatus {
  PENDING   // 老师导入后，学生尚未扫码激活
  ACTIVE    // 学生已设置密码，正式启用
  INACTIVE  // 账号禁用
}


model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  phone     String   @unique // 使用手机号作为唯一登录凭证
  password  String
  name      String?
  status    UserStatus @default(ACTIVE)
  role      Role @default(USER)

  // 关联到中间表
  memberships ClassMember[]

  // email     String   @unique
  // firstname String?
  // lastname  String?
  posts     Post[]

  // 👇 新增这一行，表示一个用户可以有多条签到记录
  attendances Attendance[]
}

// 班级/实习计划表
model Class {
  id        String   @id @default(cuid())
  name      String   // 例如："机电3班" 或 "腾讯前端实训组"
  // ... 其他属性
  
  members   ClassMember[]
}

// 多对多关系中间表
model ClassMember {
  id        String   @id @default(cuid())
  userId    String
  classId   String
  
  // 在当前班级中的角色（比如他是机电3班的普通学生，却是实训组的小组长）
  role      String   @default("STUDENT") 
  // 在当前班级中的状态（正常、退出、被管理员移出）
  status    String   @default("ACTIVE")  
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  class     Class    @relation(fields: [classId], references: [id])

  // 联合唯一索引：确保一个学生不能重复加入同一个班级两次
  @@unique([userId, classId]) 
}


// 签到表
model Attendance {
  id        String   @id @default(cuid())
  userId    String
  classId   String   // 所属班级/组织
  
  recordDate String  // 记录的日期，如 "2026-04-22"
  
  // 核心：记录的类型
  status    String   @default("WORK") // "WORK" (上班), "REST" (休息), "LEAVE" (请假)
  
  // 其他你希望保留的可选字段
  mood      String?  // 心情盲盒（可选）
  address   String?  // 定位（可选）
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])

  // 联合唯一索引：确保一个人在同一个班级，一天只能有一条记录（方便 upsert）
  @@unique([userId, classId, recordDate])
}

model Post {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  published Boolean
  title     String
  content   String?
  author    User?    @relation(fields: [authorId], references: [id])
  authorId  String?
}

