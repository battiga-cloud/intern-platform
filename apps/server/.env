# POSTGRES
POSTGRES_USER=prisma
POSTGRES_PASSWORD=topsecret
POSTGRES_DB=blog

# Nest run locally
DB_HOST=localhost
DB_PORT=5432
DB_SCHEMA=blog

# 👇 修改这一行，直接填入真实的拼接结果 👇
DATABASE_URL="postgresql://prisma:topsecret@localhost:5432/blog?schema=blog"

# Nest
PORT=3000

# Security
JWT_ACCESS_SECRET=nestjsPrismaAccessSecret
JWT_REFRESH_SECRET=nestjsPrismaRefreshSecret